<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login</title>
  </head>
  <body>
    <h1>Login</h1>
    <form>
      <label
        >Username: <input type="text" required minlength="1" name="username"
      /></label>
      <label
        >Password:
        <input required minlength="6" name="password" type="password"
      /></label>
      <label
        >Confirm Password:
        <input required minlength="6" name="confirmPassword" type="password"
      /></label>
    </form>
  </body>
</html>
